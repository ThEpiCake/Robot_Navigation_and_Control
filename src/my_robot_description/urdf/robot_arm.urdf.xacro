<?xml version="1.0"?>
<robot name="custom_rpp_zyz_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="common_properties.xacro"/>
  <xacro:include filename="robot_arm_gazebo.xacro"/>

  <xacro:property name="arm_length" value="0.3"/>
  <xacro:property name="arm_radius" value="0.035"/>

  <link name="world"/>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ========================= -->
  <!-- Base plate -->
  <!-- ========================= -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
      <geometry>
        <box size="0.20 0.20 0.02"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
      <geometry>
        <box size="0.20 0.20 0.02"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="1.0" x="0.20" y="0.20" z="0.02" o_xyz="0 0 0.01" o_rpy="0 0 0"/>
  </link>

  <!-- ========================= -->
  <!-- Rotating motor base -->
  <!-- ========================= -->
  <link name="base_motor_link">
    <visual>
      <origin xyz="0 0 ${arm_length* 0.2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius*(12/7)}" length="${arm_length* 0.4}"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${arm_length* 0.2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius*(12/7)}" length="${arm_length* 0.4}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="1.0" r="${arm_radius*(12/7)}" h="${arm_length* 0.4}" o_xyz="0 0 ${arm_length* 0.2}" o_rpy="0 0 0"/>
  </link>

  <joint name="joint_base_yaw" type="revolute">
    <parent link="base_link"/>
    <child link="base_motor_link"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${-pi}" upper="${pi}" effort="120" velocity="1.0"/>
    <dynamics damping="1.0" friction="0.2"/> 
  </joint>

  <!-- ========================= -->
  <!-- Arm 1 outer tube -->
  <!-- ========================= -->

  <xacro:macro name="outer_arm" params="parfix">
    <link name="${parfix}_outer_link">
      <visual>
        <origin xyz="0 0 ${arm_length* 0.5}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${arm_radius}" length="${arm_length}"/>
      </geometry>
        <material name="gray"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${arm_length* 0.5}" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${arm_radius}" length="${arm_length}"/>
        </geometry>
      </collision>
      <xacro:cylinder_tube_inertia m="1.0" r_outer="${arm_radius}" r_inner="${arm_radius* (5/7)}" h="${arm_length}" o_xyz="0 0 ${arm_length* 0.5}" o_rpy="0 0 0"/>
    </link>
  </xacro:macro>

  <xacro:outer_arm parfix="arm1"/>

  <joint name="joint_arm1_outer_fixed" type="fixed">
    <parent link="base_motor_link"/>
    <child link="arm1_outer_link"/>
    <origin xyz="0 0 ${arm_length* 0.4}" rpy="0 0 0"/>
  </joint>

  <!-- ========================= -->
  <!-- Arm 1 inner telescopic rod -->
  <!-- Moves along Z -->
  <!-- ========================= -->
  <link name="arm1_inner_link">
    <visual>
      <origin xyz="0 0 ${arm_length* 0.5}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius* (5/7)}" length="${arm_length}"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${arm_length* 0.5}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius* (5/7)}" length="${arm_length}"/>
      </geometry>
    </collision>
    <xacro:cylinder_tube_inertia m="1.0" r_outer="${arm_radius* (5/7)}" r_inner="${arm_radius* (4/7)}" h="${arm_length}" o_xyz="0 0 ${arm_length* 0.5}" o_rpy="0 0 0"/>
  </link>

  <joint name="joint_arm1_prismatic" type="prismatic">
    <parent link="arm1_outer_link"/>
    <child link="arm1_inner_link"/>
    <origin xyz="0 0 ${arm_length/10}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="${arm_length* 0.85}" effort="400" velocity="0.10"/>
    <dynamics damping="8.0" friction="2.0"/>
  </joint>

  <!-- ========================= -->
  <!-- Fixed tilt -->
  <!-- Part 1/2-->
  <!-- ========================= -->
  <link name="tilt_link">
    <visual>
      <origin xyz="0 0 ${arm_length* 2/15}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius* 8/7}" length="${arm_length* 4/15}"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${arm_length* 2/15}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius* 8/7}" length="${arm_length* 4/15}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="1.0" r="${arm_radius* 8/7}" h="${arm_length* 4/15}" o_xyz="0 0 ${arm_length* 2/15}" o_rpy="0 0 0"/>
  </link>

  <joint name="joint_fixed_tilt" type="fixed">
    <parent link="arm1_inner_link"/>
    <child link="tilt_link"/>
    <origin xyz="0 0 ${arm_length}" rpy="0 0 0"/>
  </joint>

  <!-- ========================= -->
  <!-- Fixed tilt by 135 degrees downward -->
  <!-- We use rotation about Y, Part 2/2-->
  <!-- ========================= -->
  <link name="tilt_135_link">
    <visual>
      <origin xyz="0 0 ${arm_length* 2/15}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius* 8/7}" length="${arm_length* 4/15}"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${arm_length* 2/15}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius* 8/7}" length="${arm_length* 4/15}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="1.0" r="${arm_radius* 8/7}" h="${arm_length* 4/15}" o_xyz="0 0 ${arm_length* 2/15}" o_rpy="0 0 0"/>
  </link>

  <joint name="joint_fixed_135deg" type="fixed">
    <parent link="tilt_link"/>
    <child link="tilt_135_link"/>
    <origin xyz="0  0 ${arm_length* 4/15}" rpy="0 ${pi/(4/3)} 0"/>
  </joint>

<!-- ========================= -->
  <!-- Arm 2 outer tube -->
  <!-- Axis is now tilted with the frame -->
  <!-- ========================= -->
  <xacro:outer_arm parfix="arm2"/>

  <joint name="joint_arm2_outer_fixed" type="fixed">
    <parent link="tilt_135_link"/>
    <child link="arm2_outer_link"/>
    <origin xyz="0 0 ${arm_length* 4/15}" rpy="0 0 0"/>
  </joint>

  <!-- ========================= -->
  <!-- Arm 2 inner telescopic rod -->
  <!-- Moves along local Z of arm2 -->
  <!-- ========================= -->
  <link name="arm2_inner_link">
    <visual>
      <origin xyz="0 0 ${arm_length* 0.5}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius* (5/7)}" length="${arm_length}"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${arm_length* 0.5}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${arm_radius* (5/7)}" length="${arm_length}"/>
      </geometry>
    </collision>
    <xacro:cylinder_tube_inertia m="1.0" r_outer="${arm_radius* (5/7)}" r_inner="${arm_radius* (4/7)}" h="${arm_length}" o_xyz="0 0 ${arm_length* 0.5}" o_rpy="0 0 0"/>
  </link>

  <joint name="joint_arm2_prismatic" type="prismatic">
    <parent link="arm2_outer_link"/>
    <child link="arm2_inner_link"/>
    <origin xyz="0 0 ${arm_length/10}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="${arm_length* 0.85}" effort="400" velocity="0.10"/>
    <dynamics damping="8.0" friction="2.0"/>
  </joint>

  <!-- ========================= -->
  <!-- Wrist Z1 1/3-->
  <!-- ========================= -->
  <link name="wrist_z1_base_link">
    <visual>
      <origin xyz="0 0 0.005" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.01"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.005" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.01"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="0.5" x="0.05" y="0.05" z="0.01" o_xyz="0 0 0.005" o_rpy="0 0 0"/>
  </link>

  <joint name="joint_wrist_z1" type="revolute">
    <parent link="arm2_inner_link"/>
    <child link="wrist_z1_base_link"/>
    <origin xyz="0 0 ${arm_length}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${-pi}" upper="${pi}" effort="80" velocity="1.0"/>
    <dynamics damping="1.5" friction="0.2"/>
  </joint>

  <!-- ========================= -->
  <!-- Wrist left Z1 2/3-->
  <!-- ========================= -->
  <xacro:macro name="wrist_z1_side" params="side">
     <link name="wrist_z1_${side}_link">
        <visual>
          <origin xyz="0 0 0.025" rpy="0 0 0"/>
          <geometry>
            <box size="0.05 0.01 0.05"/>
          </geometry>
          <material name="gray"/>
        </visual>
        <collision>
          <origin xyz="0 0 0.025" rpy="0 0 0"/>
          <geometry>
            <box size="0.05 0.01 0.05"/>
          </geometry>
        </collision>
        <xacro:box_inertia m="0.5" x="0.05" y="0.01" z="0.05" o_xyz="0 0 0.025" o_rpy="0 0 0"/>
      </link>
  </xacro:macro>

  <xacro:wrist_z1_side side="left"/>

  <joint name="joint_wrist_left_z1" type="fixed">
    <parent link="wrist_z1_base_link"/>
    <child link="wrist_z1_left_link"/>
    <origin xyz="0 0.02 0.01" rpy="0 0 0"/>
  </joint>

    <!-- ========================= -->
  <!-- Wrist right Z1 3/3-->
  <!-- ========================= -->
  <xacro:wrist_z1_side side="right"/>

  <joint name="joint_wrist_right_z1" type="fixed">
    <parent link="wrist_z1_base_link"/>
    <child link="wrist_z1_right_link"/>
    <origin xyz="0 -0.02 0.01" rpy="0 0 0"/>
  </joint>


  <!-- ========================= -->
  <!-- Wrist Y -->
  <!-- ========================= -->
  <link name="wrist_y_link">
    <visual>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.03 0.06"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.03 0.06"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="0.5" x="0.02" y="0.03" z="0.06" o_xyz="0 0 0.02" o_rpy="0 0 0"/>
  </link>

  <joint name="joint_wrist_y" type="revolute">
    <parent link="wrist_z1_base_link"/>
    <child link="wrist_y_link"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="80" velocity="1.0"/>
    <dynamics damping="1.5" friction="0.2"/>
  </joint>

  <!-- ========================= -->
  <!-- Wrist Z2 -->
  <!-- ========================= -->
  <link name="wrist_z2_link">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.018" length="0.05"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.018" length="0.05"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="1.0" r="0.018" h="0.05" o_xyz="0 0 0.025" o_rpy="0 0 0"/>
  </link>

  <joint name="joint_wrist_z2" type="revolute">
    <parent link="wrist_y_link"/>
    <child link="wrist_z2_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="60" velocity="1.0"/>
    <dynamics damping="1.0" friction="0.2"/>
  </joint>

  <!-- ========================= -->
  <!-- Gripper base -->
  <!-- ========================= -->
  <link name="gripper_base_link">
    <visual>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.06"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.06"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="0.5" x="0.03" y="0.03" z="0.06" o_xyz="0 0 0.03" o_rpy="0 0 0"/> 
  </link>

  <joint name="joint_gripper_fixed" type="fixed">
    <parent link="wrist_z2_link"/>
    <child link="gripper_base_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>

  <!-- End-effector tip- 6cm forward from gripper_base frame -->
  <link name="ee_tip_link"/>
  <joint name="joint_ee_tip_fixed" type="fixed">
    <parent link="gripper_base_link"/>
    <child link="ee_tip_link"/>
    <origin xyz="0 0 0.06" rpy="0 0 0"/>
  </joint>

  <!-- ========================= -->
  <!-- Left finger -->
  <!-- ========================= -->
  <xacro:macro name="finger" params="side">
    <link name="${side}_finger_link">
      <visual>
        <origin xyz="0 0 0.03" rpy="0 0 0"/>
        <geometry>
          <box size="0.01 0.01 0.06"/>
        </geometry>
        <material name="gray"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.03" rpy="0 0 0"/>
        <geometry>
          <box size="0.01 0.01 0.06"/>
        </geometry>
      </collision>
      <xacro:box_inertia m="0.3" x="0.01" y="0.01" z="0.06" o_xyz="0 0 0.03" o_rpy="0 0 0"/>
    </link>
  </xacro:macro>

  <xacro:finger side="left"/>

  <joint name="joint_left_finger_fixed" type="fixed">
    <parent link="gripper_base_link"/>
    <child link="left_finger_link"/>
    <origin xyz="0 0.02 0.03" rpy="0 0 0"/>
  </joint>

  <!-- ========================= -->
  <!-- Right finger -->
  <!-- ========================= -->
  <xacro:finger side="right"/>

  <joint name="joint_right_finger_fixed" type="fixed">
    <parent link="gripper_base_link"/>
    <child link="right_finger_link"/>
    <origin xyz="0 -0.02 0.03" rpy="0 0 0"/>
  </joint>

</robot>
